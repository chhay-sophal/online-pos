{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "customer-display"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "shell:allow-execute",
    "shell:allow-spawn",
    "updater:default",
    "process:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
