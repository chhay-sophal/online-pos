# =============================================================================
# SOSO BABY MART — Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and never committed.
# When running via Docker, these values are injected by docker-compose.yml
# instead — this file is only used for local development.
# =============================================================================

# --- SERVER ------------------------------------------------------------------

# Port the Express server listens on.
PORT=5050

# --- DATABASE (PostgreSQL) ---------------------------------------------------

# Hostname of the PostgreSQL server.
# For local dev: localhost
# For Docker:    set by docker-compose, not this file
DB_HOST=localhost

# PostgreSQL port (default: 5432)
DB_PORT=5432

# Database name, user, and password
DB_DATABASE=posdb
DB_USER=pos
DB_PASSWORD=

# --- BAKONG KHQR -------------------------------------------------------------
# Bakong credentials are NOT stored here — they live in the store_settings
# table and are managed through the app's Settings screen at runtime.
# =============================================================================
