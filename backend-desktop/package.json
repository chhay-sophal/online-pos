{
  "name": "backend-desktop",
  "version": "1.0.0",
  "description": "Desktop backend for SOSO Baby Mart POS (SQLite)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npx @yao-pkg/pkg server.js --targets node18-macos-arm64,node18-win-x64,node18-linux-x64 --output dist/backend-server --no-bytecode --public-packages '*' --public && node scripts/rename-sidecars.js"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bakong-khqr": "^1.0.20",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0"
  },
  "pkg": {
    "assets": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "scripts": []
  }
}
