# =============================================================================
# SOSO BABY MART — Desktop Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. Most settings (Bakong credentials, exchange rate, locale)
# are stored in the SQLite database and managed through the Settings screen.
# =============================================================================

# --- SERVER ------------------------------------------------------------------

# Port the Express server listens on.
# The Tauri frontend always connects to localhost:5050.
PORT=5050

# --- DATABASE (SQLite) -------------------------------------------------------

# Directory where the SQLite database file is stored.
# Defaults to ~/.soso-babymart-pos/ if not set.
# POS_DATA_DIR=/custom/path/to/data

# --- BAKONG KHQR PAYMENT STATUS CHECK ----------------------------------------
# These are ops-level secrets — never exposed through the Settings screen/API.
# The account ID/merchant name/city used to *generate* the QR are still
# configured in Settings, since those are public info printed on the QR itself.

# Email your Bakong Open API account is registered under. Used to auto-renew
# BAKONG_API_TOKEN when it expires (the renewed token is cached internally).
# BAKONG_REGISTERED_EMAIL=you@example.com

# Optional pre-seeded token, so the app doesn't need to call renew_token on
# first run. Leave unset to have it minted automatically from the email above.
# BAKONG_API_TOKEN=

# =============================================================================
